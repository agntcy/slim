#!/bin/sh

# Copyright AGNTCY Contributors (https://github.com/agntcy)
# SPDX-License-Identifier: Apache-2.0

# Bootstrap Gradle into .tools/ (gitignored) so developers and CI do not need a global `gradle` install.
# Pin with GRADLE_VERSION env if needed; default matches build expectations (8.5+).

set -e
GRADLE_VERSION="${GRADLE_VERSION:-8.11.1}"

ROOT="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
INSTALL_BASE="${ROOT}/.tools"
INSTALL_DIR="${INSTALL_BASE}/gradle-${GRADLE_VERSION}"
GRADLE_BIN="${INSTALL_DIR}/bin/gradle"

if [ -x "${GRADLE_BIN}" ]; then
  exec "${GRADLE_BIN}" "$@"
fi

echo "Installing Gradle ${GRADLE_VERSION} under ${INSTALL_DIR} (first run only)..."
mkdir -p "${INSTALL_BASE}"
ZIP="${INSTALL_BASE}/gradle-${GRADLE_VERSION}-bin.zip.$$"
rm -rf "${INSTALL_DIR}"
curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -o "${ZIP}"
unzip -q "${ZIP}" -d "${INSTALL_BASE}"
rm -f "${ZIP}"
# Archive unpacks to gradle-${GRADLE_VERSION}/
if [ ! -x "${GRADLE_BIN}" ]; then
  echo "Error: expected ${GRADLE_BIN} after install" >&2
  exit 1
fi
exec "${GRADLE_BIN}" "$@"

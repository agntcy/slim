#!/bin/sh

# Copyright AGNTCY Contributors (https://github.com/agntcy)
# SPDX-License-Identifier: Apache-2.0

# Bootstrap Apache Maven into .tools/ (gitignored) so developers and CI do not need `mvn` on PATH.
# Pin with MAVEN_VERSION if needed.

set -e
MAVEN_VERSION="${MAVEN_VERSION:-3.9.16}"

ROOT="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
INSTALL_BASE="${ROOT}/.tools"
INSTALL_DIR="${INSTALL_BASE}/apache-maven-${MAVEN_VERSION}"
MVN_BIN="${INSTALL_DIR}/bin/mvn"

if [ -x "${MVN_BIN}" ]; then
  exec "${MVN_BIN}" "$@"
fi

echo "Installing Apache Maven ${MAVEN_VERSION} under ${INSTALL_DIR} (first run only)..."
mkdir -p "${INSTALL_BASE}"
TGZ="${INSTALL_BASE}/apache-maven-${MAVEN_VERSION}-bin.tar.gz.$$"
rm -rf "${INSTALL_DIR}"
MAVEN_TGZ="apache-maven-${MAVEN_VERSION}-bin.tar.gz"
PRIMARY_URL="https://dlcdn.apache.org/maven/maven-3/${MAVEN_VERSION}/binaries/${MAVEN_TGZ}"
ARCHIVE_URL="https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/${MAVEN_TGZ}"
if ! curl -fsSL "${PRIMARY_URL}" -o "${TGZ}"; then
  echo "Primary Maven mirror unavailable, trying archive.apache.org..."
  curl -fsSL "${ARCHIVE_URL}" -o "${TGZ}"
fi
tar -xzf "${TGZ}" -C "${INSTALL_BASE}"
rm -f "${TGZ}"
if [ ! -x "${MVN_BIN}" ]; then
  echo "Error: expected ${MVN_BIN} after install" >&2
  exit 1
fi
exec "${MVN_BIN}" "$@"

ADK_SUPPRESS_A2A_EXPERIMENTAL_FEATURE_WARNINGS=true

# Model - any litellm-supported model string, e.g.:
#   gemini/gemini-2.0-flash  (requires GEMINI_API_KEY)
#   openai/gpt-4o            (requires OPENAI_API_KEY)
#   anthropic/claude-3-5-sonnet-20241022  (requires ANTHROPIC_API_KEY)
MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Example: Azure OpenAI
# MODEL=azure/gpt-4o
# AZURE_API_KEY=YOUR_AZURE_API_KEY_HERE
# AZURE_API_BASE=https://YOUR_RESOURCE.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview

SLIM_URL=http://localhost:46357
SLIM_NAMESPACE=agntcy
SLIM_GROUP=demo
SLIM_NAME=k8s_troubleshooting_agent
SLIM_SECRET=secretsecretsecretsecretsecretsecret

# K8s MCP Server Configuration (for connecting to k8s MCP server)
K8S_MCP_SERVER_NAMESPACE=agntcy
K8S_MCP_SERVER_GROUP=demo
K8S_MCP_SERVER_NAME=mcp_server

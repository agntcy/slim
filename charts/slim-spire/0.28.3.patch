+## @section Upstream SPIRE agent parameters
+upstream-spire-agent:
+  nameOverride: agent-upstream-placeholder
+  serviceAccount:
+    name: spire-agent-upstream
+  server:
+    port: 443
+  healthChecks:
+    port: 9981
+  persistence:
+    hostPath: /var/lib/spire/k8s/upstream-agent
+  # Join token for bootstrapping the upstream agent against the root SPIRE server.
+  # Provide ONE of the following options:
+  #
+  #   Option A – inline value (chart creates the Secret automatically):
+  #     joinToken:
+  #       value: "<token>"
+  #
+  #   Option B – reference an existing Secret:
+  #     joinToken:
+  #       existingSecret:
+  #         name: my-secret
+  #         key: token   # optional, defaults to "token"
+  #
+  joinToken:
+    # When enabled, exactly one of .value or .existingSecret.name must be provided.
+    enabled: false
+    value: ""
+    existingSecret:
+      name: ""
+      key: ""
+  # URL of the root SPIRE server's trust bundle endpoint (e.g. https://spire-bundle.example.org).
+  # When empty, insecure_bootstrap = true is set in the agent config.
+  trustBundleURL: ""
+  trustBundleFormat: "spiffe"
+  extraEnvVars: []

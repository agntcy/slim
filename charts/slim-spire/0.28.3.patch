+  namespace: {{ .Release.Namespace }}
+  labels:
+    app.kubernetes.io/component: default
+    app.kubernetes.io/instance: {{ .Release.Name }}
+    app.kubernetes.io/name: agent-upstream
+type: Opaque
+stringData:
+  token: {{ $joinToken.value | quote }}
+{{- end }}
+{{- end }}
diff --git a/charts/spire/templates/upstream-agent-rbac.yaml b/charts/spire/templates/upstream-agent-rbac.yaml
